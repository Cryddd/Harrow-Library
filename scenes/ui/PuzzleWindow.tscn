[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/PuzzleWindow.gd" id="1_puzzle"]

[node name="PuzzleWindow" type="PanelContainer"]
layout_mode = 3
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -360.0
offset_top = -250.0
offset_right = 360.0
offset_bottom = 250.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_puzzle")

[node name="Content" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="Content"]
unique_name_in_owner = true
layout_mode = 2
text = "Puzzle"

[node name="DescriptionLabel" type="Label" parent="Content"]
unique_name_in_owner = true
layout_mode = 2
autowrap_mode = 3
text = "Description"

[node name="AnswerInput" type="TextEdit" parent="Content"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 180)
layout_mode = 2

[node name="FeedbackLabel" type="Label" parent="Content"]
unique_name_in_owner = true
layout_mode = 2

[node name="Buttons" type="HBoxContainer" parent="Content"]
layout_mode = 2

[node name="RunButton" type="Button" parent="Content/Buttons"]
layout_mode = 2
text = "RUN"

[node name="CloseButton" type="Button" parent="Content/Buttons"]
layout_mode = 2
text = "CLOSE"

[connection signal="pressed" from="Content/Buttons/RunButton" to="." method="_on_run_button_pressed"]
[connection signal="pressed" from="Content/Buttons/CloseButton" to="." method="_on_close_button_pressed"]
